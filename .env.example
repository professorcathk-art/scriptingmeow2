# Copy to .env.local and fill in values. Never commit .env.local.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini
GEMINI_API_KEY=

# Optional: Google Programmable Search (Custom Search JSON API) for “related web images” in Create Post.
# Without these, the app falls back to Wikimedia Commons image search (no extra key).
# GOOGLE_CSE_API_KEY=
# GOOGLE_CSE_CX=

# Optional: AI/ML API (https://aimlapi.com) web search for “related web images” when Google CSE is unavailable.
# Uses chat + web search (default perplexity/sonar), not image generation endpoints.
# AIMLAPI_KEY=   (or AIML_API_KEY / AIMLAPI_API_KEY)
# AIMLAPI_WEB_IMAGE_MODEL=perplexity/sonar
# When AIMLAPI_KEY is set, Google CSE is skipped unless FORCE_GOOGLE_CSE=true (avoids JSON API 403 spam).
# FORCE_GOOGLE_CSE=
# SKIP_GOOGLE_CSE=true — never call Google CSE (even without AIML).
# SKIP_GOOGLE_CSE=
# Log Wikimedia “no hits” diagnostics: WEB_IMAGE_DISCOVERY_VERBOSE=true
# WEB_IMAGE_DISCOVERY_VERBOSE=

